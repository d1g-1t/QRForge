APP_NAME=QRForge
DEBUG=false

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:29101/qrforge
REDIS_URL=redis://localhost:29102/0
BASE_URL=https://yourdomain.com

GENERATION_WORKERS=4
GENERATION_CACHE_TTL_SECONDS=3600
